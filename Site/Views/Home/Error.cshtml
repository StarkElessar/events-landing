@model ErrorViewModel

@{
    ViewData["Title"] = "Ошибка";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<title>Ошибка</title>
	</head>
	<body>
		<div style="padding: 2rem; font-family: system-ui;">
			<h1>Произошла ошибка</h1>
			@if (Model.ShowRequestId)
			{
				<p>Request ID: <code>@Model.RequestId</code></p>
			}
		</div>
	</body>
</html>
