@model LandingViewModel

<section class="booking" id="booking">
	<div class="container">

		<h2 class="booking__title">Забронируйте транспорт на&nbsp;«@Model.Event.TitlePage»</h2>

		<div class="booking__inner">

			<div class="booking__form-wrap">
				<p class="booking__description">Заполните форму, и&nbsp;мы подберём оптимальный вариант транспорта для&nbsp;вас</p>

				<form class="booking__form" method="post" novalidate>
					<div class="booking__field">
						<label class="booking__label" for="booking-name">Имя</label>
						<input
							class="booking__input"
							type="text"
							id="booking-name"
							name="name"
							placeholder="Ваше имя"
							autocomplete="name"
							required
						/>
					</div>

					<div class="booking__field">
						<label class="booking__label" for="booking-phone">Телефон</label>
						<input
							class="booking__input"
							type="tel"
							id="booking-phone"
							name="phone"
							placeholder="+7 (___) ___-__-__"
							autocomplete="tel"
							required
						/>
					</div>

					<div class="booking__field">
						<label class="booking__label" for="booking-comment">Комментарий</label>
						<textarea
							class="booking__textarea"
							id="booking-comment"
							name="comment"
							placeholder="Количество человек, даты, вопросы..."
							rows="4"
						></textarea>
					</div>

					<button class="btn btn_tertiary booking__submit" type="submit">Оставить заявку</button>
				</form>
			</div>

			<div class="booking__image" aria-hidden="true"></div>

		</div>

	</div>
</section>
