@model Site.Models.Footer

<footer class="footer">
	<div class="container footer__inner">

		<div class="footer__logo-block">
			@if (!string.IsNullOrEmpty(Model.Logo))
			{
				<img class="footer__event-logo" src="@Model.Logo" alt="@Model.TransferName" />
			}
			<hr class="footer__divider" />
			<div class="footer__brand">
				@if (!string.IsNullOrEmpty(Model.TransferName))
				{
					<span class="footer__brand-name">@Model.TransferName</span>
				}
				@if (!string.IsNullOrEmpty(Model.BrandLogo))
				{
					<img class="footer__brand-logo" src="@Model.BrandLogo" alt="@Model.TransferName" />
				}
			</div>
		</div>

		<div class="footer__contacts">
			<span class="footer__contacts-label">КОНТАКТЫ</span>
			<a class="footer__phone" href="tel:@Model.ContactPhone">@Model.ContactPhone</a>
			<a class="footer__email" href="mailto:@Model.ContactEmail">@Model.ContactEmail</a>
		</div>

		<p class="footer__copyright">&copy; @DateTime.Now.Year @Model.TransferLegalAddress. Все права защищены</p>

	</div>
</footer>
