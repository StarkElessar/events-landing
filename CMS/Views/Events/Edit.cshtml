@model EventFormViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = $"Редактирование — {Model.Event.TitlePage}";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken!;
}

<div id="app"></div>

<script>
    window.__DATA__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        @event = new
        {
            id = Model.Event.Id,
            transferId = Model.Event.TransferId,
            slug = Model.Event.Slug,
            title = Model.Event.Title,
            description = Model.Event.Description,
            titlePage = Model.Event.TitlePage,
            topLogoUrl = Model.Event.TopLogoUrl,
            bottomLogoUrl = Model.Event.BottomLogoUrl,
            brandColorStart = Model.Event.BrandColorStart,
            brandColorEnd = Model.Event.BrandColorEnd,
            primaryColorStart = Model.Event.PrimaryColorStart,
            primaryColorEnd = Model.Event.PrimaryColorEnd,
            isPublished = Model.Event.IsPublished,
            isDefault = Model.Event.IsDefault,
        },
        transfers = Model.Transfers.Select(t => new { id = t.Id, name = t.Name, domain = t.Domain }),
        antiForgeryToken = token,
        siteBaseUrl = Model.SiteBaseUrl,
        hiddenFields = new Dictionary<string, string>
        {
            ["Event.Id"] = Model.Event.Id.ToString(),
            ["Event.CreatedAt"] = Model.Event.CreatedAt.ToString("o"),
        },
    }));
</script>

@section Scripts 
{
    <script type="module" vite-src="~/scripts/views/events-edit/page.tsx"></script>
}
