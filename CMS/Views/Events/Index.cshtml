@model EventListViewModel

@{
    ViewData["Title"] = "События";
    var displacedTitle = TempData["DisplacedEventTitle"] as string;
}

<div id="app"></div>

<script>
    window.__DATA__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        events = Model.Events.Select(e => new
        {
            id = e.Id,
            titlePage = e.TitlePage,
            slug = e.Slug,
            isDefault = e.IsDefault,
            isPublished = e.IsPublished,
            transfer = e.Transfer != null ? new { id = e.Transfer.Id, name = e.Transfer.Name } : null,
            effectiveBrandColorStart = e.EffectiveBrandColorStart,
            effectiveBrandColorEnd = e.EffectiveBrandColorEnd,
        }),
        siteBaseUrl = Model.SiteBaseUrl,
        displacedEventTitle = displacedTitle,
    }));
</script>

@section Scripts 
{
    <script type="module" vite-src="~/scripts/views/events-index/page.tsx"></script>
}
