@model EventFormViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "Создать событие";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken!;
}

<div id="app"></div>

<script>
    window.__DATA__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        @event = new
        {
            transferId = Model.Event.TransferId,
            slug = Model.Event.Slug ?? "",
            title = Model.Event.Title ?? "",
            description = Model.Event.Description ?? "",
            titlePage = Model.Event.TitlePage ?? "",
            topLogoUrl = (string?)null,
            bottomLogoUrl = (string?)null,
            brandColorStart = (string?)null,
            brandColorEnd = (string?)null,
            primaryColorStart = (string?)null,
            primaryColorEnd = (string?)null,
            isPublished = Model.Event.IsPublished,
            isDefault = Model.Event.IsDefault,
        },
        transfers = Model.Transfers.Select(t => new { id = t.Id, name = t.Name, domain = t.Domain }),
        antiForgeryToken = token,
        siteBaseUrl = Model.SiteBaseUrl,
    }));
</script>

@section Scripts
{
    <script type="module" vite-src="~/scripts/views/events-create/page.tsx"></script>
}
