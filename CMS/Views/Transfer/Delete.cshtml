@model TransferDeleteViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = $"Удалить — {Model.Transfer.Name}";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken!;
}

<div id="app"></div>

<script>
    window.__DATA__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        transfer = new
        {
            id = Model.Transfer.Id,
            name = Model.Transfer.Name,
            slug = Model.Transfer.Slug,
            domain = Model.Transfer.Domain,
        },
        antiForgeryToken = token,
    }));
</script>

@section Scripts 
{
    <script type="module" vite-src="~/scripts/views/transfers-delete/page.tsx"></script>
}
