@model TransferFormViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "Новый трансфер";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken!;
}

<div id="app"></div>

<script>
    window.__DATA__ = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        transfer = new
        {
            name = Model.Transfer.Name,
            slug = Model.Transfer.Slug,
            domain = Model.Transfer.Domain,
            logoUrl = Model.Transfer.LogoUrl ?? "",
            brandColorStart = Model.Transfer.BrandColorStart,
            brandColorEnd = Model.Transfer.BrandColorEnd,
            primaryColorStart = Model.Transfer.PrimaryColorStart,
            primaryColorEnd = Model.Transfer.PrimaryColorEnd,
            phone = Model.Transfer.Phone,
            email = Model.Transfer.Email,
            legalAddress = Model.Transfer.LegalAddress,
            transportType = Model.Transfer.TransportType,
            inn = Model.Transfer.INN ?? "",
            ogrn = Model.Transfer.OGRN ?? "",
        },
        antiForgeryToken = token,
    }));
</script>

@section Scripts 
{
    <script type="module" vite-src="~/scripts/views/transfers-create/page.tsx"></script>
}
