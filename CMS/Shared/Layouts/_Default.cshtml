@using CMS.Infrastructure
@using Microsoft.AspNetCore.Mvc.Controllers
@using System.Reflection
@inject Microsoft.AspNetCore.Mvc.Infrastructure.IActionDescriptorCollectionProvider ActionDescriptors
@inject Vite.AspNetCore.IViteDevServerStatus ViteDevServer

@{
	var navItems = ActionDescriptors.ActionDescriptors.Items
	                                .OfType<ControllerActionDescriptor>()
	                                .Select(a => (Descriptor: a, Nav: a.MethodInfo.GetCustomAttribute<AdminNavLinkAttribute>()))
	                                .Where(x => x.Nav is not null)
	                                .OrderBy(x => x.Nav!.Order)
	                                .Select(x => new AdminNavItem
	                                 {
		                                 Href = Url.Action(x.Descriptor.ActionName, x.Descriptor.ControllerName),
		                                 Label = x.Nav!.Label
	                                 })
	                                .ToList();

	string? reactRefreshUrl = ViteDevServer.IsEnabled
		? $"{ViteDevServer.ServerUrlWithBasePath.TrimEnd('/')}/@react-refresh"
		: null;
}

<!DOCTYPE html>
<html lang="ru">
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>@ViewData["Title"] — Админка</title>
		<link rel="stylesheet" vite-href="~/styles/main.scss"/>
		@await RenderSectionAsync("Head", required: false)
	</head>
	<body>
		<div class="admin-layout">
			<aside class="admin-sidebar">
				<div class="admin-sidebar__title">Админка</div>
				<ul class="admin-nav">
					@foreach (var item in navItems)
					{
						<li>
							<a class="admin-nav__link" href="@item.Href">@item.Label</a>
						</li>
					}
				</ul>
			</aside>
			<main class="admin-main">
				@RenderBody()
			</main>
		</div>

		<script>
	        window.__ROUTES__ = {
		        uploadEndpoint: "@Url.Action("Upload", "Uploads")",
		        events: {
			        index: "@Url.Action("Index", "Events")",
			        create: "@Url.Action("Create", "Events")",
			        editTemplate: "@(Url.Action("Edit", "Events", new { id = 0 })!.Replace("0", "{id}"))",
			        deleteTemplate: "@(Url.Action("Delete", "Events", new { id = 0 })!.Replace("0", "{id}"))",
			        deleteConfirmedTemplate: "@(Url.Action("DeleteConfirmed", "Events", new { id = 0 })!.Replace("0", "{id}"))",
		        },
		        transfers: {
			        index: "@Url.Action("Index", "Transfer")",
			        create: "@Url.Action("Create", "Transfer")",
			        editTemplate: "@(Url.Action("Edit", "Transfer", new { id = 0 })!.Replace("0", "{id}"))",
			        deleteTemplate: "@(Url.Action("Delete", "Transfer", new { id = 0 })!.Replace("0", "{id}"))",
			        deleteConfirmedTemplate: "@(Url.Action("DeleteConfirmed", "Transfer", new { id = 0 })!.Replace("0", "{id}"))",
		        },
	        }
	    </script>
		@if (reactRefreshUrl is not null)
		{
			<script type="module">
	            import { injectIntoGlobalHook } from '@(reactRefreshUrl)'
	            injectIntoGlobalHook(window)
	            window.$RefreshReg$ = () => {}
	            window.$RefreshSig$ = () => (type) => type
	            window.__vite_plugin_react_preamble_installed__ = true
	        </script>
		}
		<script type="module" vite-src="~/scripts/main.ts"></script>
		@await RenderSectionAsync("Scripts", required: false)
	</body>
</html>
